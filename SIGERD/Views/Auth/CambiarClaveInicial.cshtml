@model SIGERD.ViewModels.Auth.CambiarClaveInicialViewModel

@{
    ViewData["Title"] = "Cambiar contraseña inicial";
    Layout = "_AuthLayout";
}

<div class="auth-page">

    <main class="auth-content">

        <div class="auth-card auth-card-small">

            <div class="auth-card-header">

                <div class="auth-logo-main">
                    <i class="bi bi-shield-lock-fill"></i>
                    <span>SIGERD</span>
                </div>

                <p>
                    Seguridad de la cuenta
                </p>

            </div>

            <div class="auth-card-body">

                <h2>Cambiar contraseña inicial</h2>

                <p class="auth-subtitle">
                    Debe establecer una contraseña personal antes de continuar.
                </p>

                <form asp-action="CambiarClaveInicial" asp-controller="Auth" method="post">

                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="NuevaClave" class="form-label"></label>

                        <div class="auth-input-group">
                            <i class="bi bi-lock"></i>
                            <input asp-for="NuevaClave"
                                   type="password"
                                   class="form-control"
                                   placeholder="Ingrese su nueva contraseña"
                                   autocomplete="new-password" />
                        </div>

                        <span asp-validation-for="NuevaClave" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmarClave" class="form-label"></label>

                        <div class="auth-input-group">
                            <i class="bi bi-lock-fill"></i>
                            <input asp-for="ConfirmarClave"
                                   type="password"
                                   class="form-control"
                                   placeholder="Confirme su nueva contraseña"
                                   autocomplete="new-password" />
                        </div>

                        <span asp-validation-for="ConfirmarClave" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn auth-login-button w-100">

                        <i class="bi bi-check2-circle me-2"></i>

                        Actualizar contraseña

                    </button>

                </form>

            </div>

        </div>

    </main>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}