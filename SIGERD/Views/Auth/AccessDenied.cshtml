@{
    ViewData["Title"] = "Acceso denegado";
    Layout = "_AuthLayout";
}

<div class="auth-page">

    <main class="auth-content">

        <div class="auth-card auth-card-small">

            <div class="auth-card-body text-center">

                <div class="display-5 text-danger mb-3">
                    <i class="bi bi-shield-exclamation"></i>
                </div>

                <h2>Acceso denegado</h2>

                <p class="text-muted">
                    No tiene permisos para acceder a esta sección del sistema.
                </p>

                <a asp-controller="Dashboard" asp-action="Index" class="btn auth-login-button mt-3">
                    Volver al Dashboard
                </a>

            </div>

        </div>

    </main>

</div>