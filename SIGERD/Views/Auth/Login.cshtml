@model SIGERD.ViewModels.Auth.LoginViewModel

@{
    ViewData["Title"] = "Iniciar sesión";
    Layout = "_AuthLayout";
}

<div class="auth-page">

    <div class="auth-brand-top">

        <div class="auth-brand-logo">
            <i class="bi bi-box-seam-fill"></i>
            <span>SIGERD</span>
        </div>

        <div class="auth-brand-title">
            Sistema de Gestión y Trazabilidad de Envíos Institucionales
        </div>

    </div>

    <main class="auth-content">

        <div class="auth-card">

            <div class="auth-card-header">

                <div class="auth-logo-main">
                    <i class="bi bi-box-seam-fill"></i>
                    <span>SIGERD</span>
                </div>

                <p>
                    Sistema de Gestión y Trazabilidad de Envíos Institucionales
                </p>

            </div>

            <div class="auth-card-body">

                <h2>Iniciar sesión</h2>

                <p class="auth-subtitle">
                    Acceda con su usuario institucional.
                </p>

                <form asp-action="Login" asp-controller="Auth" method="post">

                    @Html.AntiForgeryToken()

                    <input asp-for="ReturnUrl" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="NombreUsuario" class="form-label"></label>

                        <div class="auth-input-group">
                            <i class="bi bi-person"></i>
                            <input asp-for="NombreUsuario"
                                   class="form-control"
                                   placeholder="Ingrese su nombre de usuario" />
                        </div>

                        <span asp-validation-for="NombreUsuario" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Clave" class="form-label"></label>

                        <div class="auth-input-group">
                            <i class="bi bi-lock"></i>
                            <input asp-for="Clave"
                                   type="password"
                                   class="form-control"
                                   placeholder="Ingrese su contraseña"
                                   autocomplete="current-password" />
                        </div>

                        <span asp-validation-for="Clave" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4">

                        <div class="form-check">
                            <input asp-for="Recordarme" class="form-check-input" />
                            <label asp-for="Recordarme" class="form-check-label"></label>
                        </div>

                        <span class="auth-help-text">
                            ¿Problemas para iniciar sesión?
                        </span>

                    </div>

                    <button type="submit" class="btn auth-login-button w-100">

                        <i class="bi bi-box-arrow-in-right me-2"></i>

                        Iniciar sesión

                    </button>

                </form>

                <div class="auth-helper mt-4">

                    <i class="bi bi-info-circle me-2"></i>

                    <span>
                        Si olvidó su contraseña, solicite un restablecimiento al administrador.
                    </span>

                </div>

            </div>

        </div>

        <div class="auth-info-box">

            <div class="auth-info-icon">
                <i class="bi bi-shield-check"></i>
            </div>

            <div>
                <strong>Importante</strong>
                <p class="mb-0">
                    Por su seguridad, es posible que se le solicite cambiar su contraseña inicial al ingresar al sistema.
                </p>
            </div>

        </div>

    </main>

    <footer class="auth-footer">
        © @DateTime.Now.Year SIGERD - Sistema de Gestión y Trazabilidad de Envíos Institucionales
    </footer>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}