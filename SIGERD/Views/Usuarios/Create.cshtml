@model SIGERD.ViewModels.Seguridad.Usuarios.UsuarioCreateViewModel

@{
    ViewData["Title"] = "Crear Usuario";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">

    <div>
        <h2 class="mb-1">Crear Usuario</h2>

        <p class="text-muted mb-0">
            Registra una nueva cuenta de acceso para SIGERD.
        </p>
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-2"></i>
        Volver al listado
    </a>

</div>

<div class="card shadow-sm border-0">

    <div class="card-header bg-white border-bottom pt-4 px-4">

        <h5 class="mb-1">
            Información del usuario
        </h5>

        <p class="text-muted mb-0">
            El usuario deberá cambiar la contraseña inicial al iniciar sesión por primera vez.
        </p>

    </div>

    <div class="card-body p-4">

        <form asp-action="Create" method="post">

            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">

                <div class="col-12 col-md-6">
                    <label asp-for="NombreCompleto" class="form-label"></label>
                    <input asp-for="NombreCompleto" class="form-control" />
                    <span asp-validation-for="NombreCompleto" class="text-danger"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label asp-for="NombreUsuario" class="form-label"></label>
                    <input asp-for="NombreUsuario" class="form-control" />
                    <span asp-validation-for="NombreUsuario" class="text-danger"></span>
                    <div class="form-text">
                        Use letras, números, punto, guion o guion bajo. Sin espacios.
                    </div>
                </div>

                <div class="col-12 col-md-6">
                    <label asp-for="Correo" class="form-label"></label>
                    <input asp-for="Correo" class="form-control" />
                    <span asp-validation-for="Correo" class="text-danger"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label asp-for="IdRol" class="form-label"></label>
                    <select asp-for="IdRol" asp-items="Model.Roles" class="form-select">
                        <option value="0">Seleccione un rol</option>
                    </select>
                    <span asp-validation-for="IdRol" class="text-danger"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label asp-for="IdDelegacion" class="form-label"></label>
                    <select asp-for="IdDelegacion" asp-items="Model.Delegaciones" class="form-select">
                        <option value="0">Seleccione una delegación</option>
                    </select>
                    <span asp-validation-for="IdDelegacion" class="text-danger"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label asp-for="Clave" class="form-label"></label>
                    <input asp-for="Clave" class="form-control" />
                    <span asp-validation-for="Clave" class="text-danger"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label asp-for="ConfirmarClave" class="form-label"></label>
                    <input asp-for="ConfirmarClave" class="form-control" />
                    <span asp-validation-for="ConfirmarClave" class="text-danger"></span>
                </div>

            </div>

            <div class="d-flex justify-content-end gap-2 mt-4">

                <a asp-action="Index" class="btn btn-secondary">
                    Cancelar
                </a>

                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save me-2"></i>
                    Guardar Usuario
                </button>

            </div>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}