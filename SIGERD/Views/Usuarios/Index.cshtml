@model IEnumerable<SIGERD.ViewModels.Seguridad.Usuarios.UsuarioListViewModel>

@{
    ViewData["Title"] = "Usuarios";
}



<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="mb-0">
            Gestión de Usuarios
        </h2>

        

        <a asp-action="Create"
           class="btn btn-primary">

            <i class="bi bi-plus-circle"></i>

            Nuevo Usuario

        </a>

    </div>

    <partial name="_Alerts" />

    <table class="table table-striped table-hover">

        <thead class="table-dark">

            <tr>

                <th>Nombre</th>

                <th>Correo</th>

                <th>Rol</th>

                <th>Estado</th>

                <th width="220" class="align-items-center text-center">Acciones</th>

            </tr>

        </thead>

        <tbody>

            @foreach (var item in Model)
            {

                <tr>

                    <td>@item.NombreCompleto</td>

                    <td>@item.Correo</td>

                    <td>@item.Rol</td>

                    <td>

                        @if (item.Estado)
                        {
                            <span class="badge bg-success">

                                Activo

                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger">

                                Inactivo

                            </span>
                        }

                    </td>

                    <td>

                        <a asp-action="Details"
                           asp-route-id="@item.IdUsuario"
                           class="btn btn-info btn-sm align-items-center me-2 w-25">

                            Ver

                        </a>

                        <a asp-action="Edit"
                           asp-route-id="@item.IdUsuario"
                           class="btn btn-warning btn-sm align-items-center me-2 w-25">

                            Editar

                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.IdUsuario"
                           class="btn btn-danger btn-sm">

                            Eliminar

                        </a>

                    </td>

                </tr>

            }

        </tbody>

    </table>

</div>